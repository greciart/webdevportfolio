    clientName: "NDA Client",
    clientLocation: "USA",
    rating: 5,
    date: "Feb 2025",
    screenshotUrl: "/images/reviews/clientnda.png",
    transcription: "Grecia did a wonderful job for us and we highly recommend her work to others",
    reviewUrl: "https://www.fiverr.com/s/rE4LEvP",
    projectUrl: "",

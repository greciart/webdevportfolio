---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type GalleryImage = { url: ImageMetadata; alt: string };

const { images = [] }: { images?: GalleryImage[] } = Astro.props;

const isLandscape = (img: GalleryImage) => img.url.height <= img.url.width;
// Landscape shots are short enough to stack several per page; tall page
// captures each fill the viewport on their own.
const allLandscape = images.length > 0 && images.every(isLandscape);
---

{images.length > 0 && (
  <div class="max-xl:hidden">
    <div class="sticky w-64 top-14 mt-16 max-h-[calc(100svh-3.5rem)] flex flex-col gap-3 overflow-hidden">

      <div class="relative w-full rounded-2xl border border-neutral-100 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 overflow-hidden">

        <div id="gallery-viewport" class="relative w-full overflow-hidden">
          <div
            id="gallery-track"
            class="flex flex-col transition-transform duration-500 ease-in-out"
            data-stacked={allLandscape ? 'true' : 'false'}
          >
            {images.map((img) => (
              <a
                class="gallery-slide block"
                href={(img.url as any).src}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Ver imagen completa"
              >
                {isLandscape(img) ? (
                  <Image
                    src={img.url}
                    alt={img.alt}
                    class="w-full aspect-video object-contain object-center hover:opacity-90 transition-opacity duration-300"
                  />
                ) : (
                  <Image
                    src={img.url}
                    alt={img.alt}
                    class="w-full object-cover object-top hover:opacity-90 transition-opacity duration-300"
                    style="height: calc(100svh - 10rem);"
                  />
                )}
              </a>
            ))}
          </div>
        </div>

        {images.length > 1 && (
          <div id="gallery-nav" class="flex items-center justify-between px-3 py-2 bg-white/5 backdrop-blur-sm">
            <button
              id="gallery-prev"
              class="text-xs text-mint-400 hover:text-mint-300 transition-colors disabled:opacity-30 font-bold px-2 py-1 rounded"
              aria-label="Imagen anterior"
            >
              ← Prev
            </button>
            <span id="gallery-counter" class="text-xs text-neutral-400">1 / {images.length}</span>
            <button
              id="gallery-next"
              class="text-xs text-mint-400 hover:text-mint-300 transition-colors disabled:opacity-30 font-bold px-2 py-1 rounded"
              aria-label="Siguiente imagen"
            >
              Next →
            </button>
          </div>
        )}
      </div>

    </div>
  </div>
)}

<script>
  const viewport = document.getElementById('gallery-viewport') as HTMLElement;
  const track = document.getElementById('gallery-track') as HTMLElement;
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.gallery-slide'));
  const counter = document.getElementById('gallery-counter');
  const prevBtn = document.getElementById('gallery-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('gallery-next') as HTMLButtonElement;

  const stacked = track?.dataset.stacked === 'true';
  const wideScreen = window.matchMedia('(min-width: 1536px)');

  let perPage = 1;
  let pageCount = 1;
  let current = 0;

  function slideBottom(slide: HTMLElement) {
    return slide.offsetTop + slide.offsetHeight;
  }

  function layout() {
    // Measured from live offsets rather than a computed item height, so the
    // math survives the flex gap and a partial last page.
    perPage = stacked ? (wideScreen.matches ? 4 : 3) : 1;
    pageCount = Math.max(1, Math.ceil(slides.length / perPage));
    if (current > pageCount - 1) current = pageCount - 1;

    const lastVisible = slides[Math.min(perPage, slides.length) - 1];
    if (viewport && slides[0] && lastVisible) {
      viewport.style.height = `${slideBottom(lastVisible) - slides[0].offsetTop}px`;
    }
    render();
  }

  function render() {
    const first = slides[current * perPage];
    if (track && first && viewport) {
      // Clamp the last page against the end of the track so it fills with real
      // images instead of trailing blank space.
      const maxOffset = Math.max(0, track.scrollHeight - viewport.clientHeight);
      track.style.transform = `translateY(-${Math.min(first.offsetTop, maxOffset)}px)`;
    }
    if (counter) counter.textContent = `${current + 1} / ${pageCount}`;
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === pageCount - 1;
  }

  if (slides.length > 0) {
    layout();
    prevBtn?.addEventListener('click', () => { if (current > 0) { current--; render(); } });
    nextBtn?.addEventListener('click', () => { if (current < pageCount - 1) { current++; render(); } });
    window.addEventListener('resize', layout);
    window.addEventListener('load', layout);
    wideScreen.addEventListener('change', layout);
  }
</script>
